<?xml version="1.0"?>
<robot name="gercek_otonom_forklift">

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.345" rpy="0.0 0.0 0.0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.0 0.59 0.49"/>
      </geometry>
      <material name="turuncu">
        <color rgba="1.0 0.42 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 0.59 0.49"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="45.0"/>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <inertia ixx="2.1" ixy="0.0" ixz="0.0" iyy="4.3" iyz="0.0" izz="4.8"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.35 0.325 -0.27" rpy="-1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.06"/>
      </geometry>
      <material name="siyah"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.075" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.35 -0.325 -0.27" rpy="1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.075" length="0.06"/>
      </geometry>
      <material name="siyah"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.075" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster"/>
    <origin xyz="0.45 0.25 -0.32" rpy="0.0 0.0 0.0"/>
  </joint>
  
  <link name="front_left_caster">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="gri"><color rgba="0.4 0.4 0.4 1.0"/></material>
    </visual>
    <collision><geometry><sphere radius="0.025"/></geometry></collision>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster"/>
    <origin xyz="0.45 -0.25 -0.32" rpy="0.0 0.0 0.0"/>
  </joint>
  
  <link name="front_right_caster">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="gri"><color rgba="0.4 0.4 0.4 1.0"/></material>
    </visual>
    <collision><geometry><sphere radius="0.025"/></geometry></collision>
  </link>


  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.1 0.0 0.26" rpy="0.0 0.6108 0.0"/>
  </joint>
  
  <link name="camera_link">
    <visual>
      <geometry><box size="0.05 0.06 0.04"/></geometry>
      <material name="mavi_sensor"><color rgba="0.0 0.3 0.9 1.0"/></material>
    </visual>
    <collision><geometry><box size="0.05 0.06 0.04"/></geometry></collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.0 0.0 0.055" rpy="0.0 -0.6108 0.0"/>
  </joint>
  
  <link name="laser_frame">
    <visual>
      <geometry><cylinder radius="0.04" length="0.03"/></geometry>
      <material name="kirmizi"><color rgba="0.9 0.0 0.0 1.0"/></material>
    </visual>
    <collision><geometry><cylinder radius="0.04" length="0.03"/></geometry></collision>
  </link>


  <gazebo reference="base_link"><material>Gazebo/Orange</material></gazebo>
  <gazebo reference="left_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="right_wheel"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="laser_frame"><material>Gazebo/Red</material></gazebo>
  <gazebo reference="camera_link"><material>Gazebo/Blue</material></gazebo>

  <gazebo>
    <plugin name="forklift_planar_move" filename="libgazebo_ros_planar_move.so">
      <ros><namespace>/</namespace></ros>
      <update_rate>100</update_rate>
      <publish_rate>50</publish_rate>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
  </gazebo>

  <gazebo reference="laser_frame">
    <sensor name="laser" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
        <range><min>0.2</min><max>12.0</max><resolution>0.01</resolution></range>
      </ray>
      <plugin name="laser_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros><argument>~/out:=scan</argument></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>